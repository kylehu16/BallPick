.page-team-select {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F6F8;
}

.nav-header-content {
  position: relative;
  padding: 16rpx 32rpx 32rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-left, .nav-right {
  width: 64rpx;
  display: flex;
  align-items: center;
}

.icon-back {
  font-size: 48rpx;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 32rpx 12rpx;
  background: #F5F6F8;
  flex-shrink: 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1D2129;
}

.search-clear {
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 4rpx;
}

/* 已选计数 */
.selected-bar {
  padding: 0 32rpx 12rpx;
  background: #F5F6F8;
  flex-shrink: 0;
}

.selected-text {
  font-size: 24rpx;
  color: #155DFC;
  font-weight: 500;
}

/* 国家列表 */
.country-list {
  flex: 1;
}

.country-list-inner {
  padding: 0 48rpx 0 32rpx;
}

.country-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx 32rpx 18rpx 20rpx;
  margin-bottom: 12rpx;
  gap: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.country-checked {
  background: #EFF6FF;
  border: 2rpx solid #155DFC;
}

.country-flag {
  width: 56rpx;
  height: 40rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.country-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.country-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.country-name-en {
  font-size: 20rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-active {
  background: #155DFC;
  border-color: #155DFC;
}

.check-mark {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}

/* 翻页器 */
.paginator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 32rpx;
  background: #fff;
  flex-shrink: 0;
}

.page-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #EFF6FF;
}

.page-btn-disabled {
  opacity: 0.4;
}

.page-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #155DFC;
}

.page-info {
  font-size: 26rpx;
  color: #717182;
}

/* 底部确认 */
.footer-bar {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  flex-shrink: 0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: #155DFC;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}

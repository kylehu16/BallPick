.page-guess {
  min-height: 100vh;
  background: linear-gradient(180deg, #EFF6FF 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
}

.nav-header-content {
  position: relative;
  padding: 16rpx 48rpx 32rpx;
  z-index: 2;
}

.nav-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
}

.nav-subtitle {
  font-size: 28rpx;
  color: #DBEAFE;
  display: block;
  margin-top: 8rpx;
}

/* 竞猜统计行 */
.stats-row {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 16rpx;
}

.stats-card {
  flex: 1;
  background: #ffffff;
  border-radius: 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  padding: 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
}

.stats-number-blue {
  color: #155DFC;
}

.stats-number-green {
  color: #00A63E;
}

.stats-number-purple {
  color: #9810FA;
}

.stats-label {
  font-size: 24rpx;
  color: #717182;
}

/* 竞猜列表 */
.guess-list {
  flex: 1;
  padding: 8rpx 0 160rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 竞猜卡片 */
.guess-card {
  background: #ffffff;
  border-radius: 28rpx;
  margin: 0 32rpx 20rpx;
  overflow: hidden;
}

.guess-card-inner {
  padding: 32rpx;
}

/* 不同状态边框 */
.guess-card-correct {
  border: 2rpx solid #00C950;
  border-left: 8rpx solid #00C950;
}

.guess-card-live {
  border: 2rpx solid #FF8904;
  border-left: 8rpx solid #FF8904;
}

.guess-card-pending {
  border: 2rpx solid #51A2FF;
  border-left: 8rpx solid #51A2FF;
}

.guess-card-wrong {
  border: 2rpx solid #EF4444;
  border-left: 8rpx solid #EF4444;
}

.guess-card-finished {
  border: 2rpx solid #9CA3AF;
  border-left: 8rpx solid #9CA3AF;
}

/* 卡片头部 */
.guess-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.guess-tags {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.tag-tournament {
  font-size: 24rpx;
  font-weight: 500;
  color: #0A0A0A;
  padding: 4rpx 18rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  line-height: 1.4;
}

.tag-type {
  font-size: 24rpx;
  font-weight: 500;
  color: #9810FA;
  padding: 4rpx 18rpx;
  border-radius: 16rpx;
  border: 2rpx solid #DAB2FF;
  line-height: 1.4;
}

.guess-date {
  font-size: 24rpx;
  color: #717182;
  flex-shrink: 0;
}

/* 卡片主体 */
.guess-card-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.guess-info {
  flex: 1;
  min-width: 0;
}

.guess-match {
  font-size: 28rpx;
  font-weight: 500;
  color: #0A0A0A;
  display: block;
  margin-bottom: 12rpx;
}

.guess-match-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.guess-flag {
  width: 48rpx;
  height: 34rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.guess-team-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #0A0A0A;
}

.guess-vs {
  font-size: 24rpx;
  color: #717182;
  margin: 0 4rpx;
}

.guess-detail {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.guess-detail-label {
  font-size: 24rpx;
  color: #717182;
}

.guess-detail-value {
  font-size: 24rpx;
  font-weight: 500;
  color: #364153;
}

/* 状态标签 */
.guess-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 16rpx;
  margin-top: 8rpx;
}

.guess-status-correct {
  background: #F0FDF4;
  color: #00A63E;
}

.guess-status-live {
  background: #FFF7ED;
  color: #FF6900;
}

.guess-status-pending {
  background: #EFF6FF;
  color: #2B7FFF;
}

.guess-status-wrong {
  background: #FEF2F2;
  color: #DC2626;
}

.guess-status-finished {
  background: #F9FAFB;
  color: #6B7280;
}

.status-icon {
  width: 16rpx;
  height: 16rpx;
}



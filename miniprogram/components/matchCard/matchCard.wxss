.match-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  margin: 0 32rpx 24rpx;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* 赛事标签 + 状态标签 */
.card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 12rpx;
}

.tag-match {
  display: inline-flex;
  align-items: center;
  background: #FEF9C2;
  border: 2rpx solid #FFDF20;
  border-radius: 16rpx;
  padding: 4rpx 18rpx;
}

.tag-match-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #A65F00;
}

/* LIVE 标签 - 红色闪烁 */
.tag-live {
  display: inline-flex;
  align-items: center;
  background: #FEE2E2;
  border: 2rpx solid #FCA5A5;
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.tag-live-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #DC2626;
}

/* 已结束标签 */
.tag-finished {
  display: inline-flex;
  align-items: center;
  background: #F3F4F6;
  border: 2rpx solid #D1D5DB;
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
}

.tag-finished-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #6B7280;
}

/* 队伍 VS 区域 */
.card-body {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 0 32rpx 24rpx;
}

.team-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.team-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1);
}

.team-flag {
  width: 96rpx;
  height: 68rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1);
}

.team-avatar-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.team-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-top: 16rpx;
  text-align: center;
}

/* VS / 比分 中间区域 */
.vs-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
  min-width: 180rpx;
}

.vs-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #717182;
}

.match-date,
.match-time {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.icon-calendar,
.icon-clock {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
  opacity: 0.5;
}

.date-text,
.time-text {
  font-size: 24rpx;
  font-weight: 400;
  color: #717182;
}

/* 比分面板 */
.score-board {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #1D2129;
  min-width: 48rpx;
  text-align: center;
}

.score-colon {
  font-size: 40rpx;
  font-weight: 700;
  color: #9CA3AF;
}

.live-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #DC2626;
  margin-top: 8rpx;
}

/* 竞猜按钮 */
.card-footer {
  display: flex;
  padding: 12rpx 32rpx 24rpx;
  gap: 16rpx;
}

.btn-guess {
  flex: 1;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-guess-outline {
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.btn-guess-filled {
  background: #030213;
  border: 2rpx solid #030213;
}

.btn-guess-text {
  font-size: 28rpx;
  font-weight: 500;
}

.btn-guess-text-dark {
  color: var(--text-primary);
}

.btn-guess-text-light {
  color: #ffffff;
}

/* AI 预测区域 */
.ai-predict {
  margin: 0 32rpx 20rpx;
  background: linear-gradient(135deg, #F0F7FF 0%, #EBF4FF 100%);
  border: 1rpx solid rgba(21, 93, 252, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.ai-predict-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.ai-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.ai-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #155DFC;
  letter-spacing: 1rpx;
}

.ai-predict-body {
  display: flex;
  flex-direction: column;
}

.ai-result-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ai-winner {
  font-size: 26rpx;
  font-weight: 600;
  color: #1D2129;
}

.ai-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #155DFC;
  background: rgba(21, 93, 252, 0.08);
  padding: 2rpx 16rpx;
  border-radius: 8rpx;
}

.ai-confidence {
  font-size: 22rpx;
  color: #86909C;
}

.ai-reasoning {
  font-size: 22rpx;
  color: #4E5969;
  margin-top: 10rpx;
  line-height: 1.5;
}
